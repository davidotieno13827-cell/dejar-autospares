# ============================================================================
# DEJAR AUTO SUPPLIES - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual production values
# IMPORTANT: Never commit .env with real credentials to version control!

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-super-secret-flask-key-here-change-in-production

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Connection String (production)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://deejar_user:change_this_password@localhost:5432/deejar_auto

# Alternative: SQLite for development (uncomment to use)
# DATABASE_URL=sqlite:///deejar_auto.db

# ============================================================================
# PAYMENT CONFIGURATION
# ============================================================================
# Use this Paybill number for customer payments and order confirmation.
PAYBILL_NUMBER=542542
BUSINESS_ACCOUNT=131141
PAYMENT_HELP_PHONE=+254721419479

# ============================================================================
# ETIMS / INVOICE INTEGRATION
# ============================================================================
ETIMS_API_URL=https://api.etims.example.com/v1/invoices
ETIMS_API_KEY=your_etims_api_key_here

# ============================================================================
# GOOGLE OAUTH 2.0 CONFIGURATION
# ============================================================================
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://deejaraoutospares.co.ke/auth/google/callback

# Authorized admin email addresses (comma-separated)
AUTHORIZED_ADMIN_EMAILS=admin@example.com,owner@dejarautosupplies.co.ke

# ============================================================================
# PAYMENT NOTIFICATION & CALLBACKS
# ============================================================================
# Email configuration for order notifications
NOTIFICATION_EMAIL=orders@deejaraoutospares.co.ke
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Webhook secret for payment callbacks
WEBHOOK_SECRET=your-secure-webhook-secret-here

# ============================================================================
# BUSINESS CONFIGURATION
# ============================================================================
# Default VAT/Tax Rate (in percentage)
DEFAULT_TAX_RATE=16.0

# Business details
BUSINESS_NAME=Dejar Auto Supplies
BUSINESS_EMAIL=info@dejarautosupplies.co.ke
BUSINESS_PHONE=+254721419479
BUSINESS_LOCATION=Hospital Road, Near KPLC Office, Opposite Quickmart, Kisii, Kenya
BUSINESS_PIN=P051XXXXXXZ

# ============================================================================
# DEPLOYMENT & SERVER CONFIGURATION
# ============================================================================
PORT=5000
HOST=0.0.0.0

# Production domain
PRODUCTION_DOMAIN=https://deejaraoutospares.co.ke
DEVELOPMENT_DOMAIN=http://localhost:5000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/dejar_auto.log

# ============================================================================
# SECURITY
# ============================================================================
# CORS settings
CORS_ALLOWED_ORIGINS=https://deejaraoutospares.co.ke,https://www.deejaraoutospares.co.ke

# API Rate limiting
RATE_LIMIT_ENABLED=1
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
